{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyEva",
  "version": "0.1.0",
  "identifier": "com.myeva.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyEva",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all", "icon": [] }
}
